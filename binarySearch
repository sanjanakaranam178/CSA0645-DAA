def binarySearch(arr, key):
    arr.sort()

    left = 0
    right = len(arr)-1

    while left <= right:
        mid = (left + right) // 2

        if arr[mid] == key:
            return mid + 1

        elif arr[mid] < key:
            left = mid + 1

        else:
            right = mid - 1

    return -1


arr = [3,4,6,-9,10,8,9,30]

key = 10
result = binarySearch(arr, key)

if result != -1:
    print("Element found at position", result)
else:
    print("Element not found")
