def findMinMax(arr):
    if len(arr) == 0:
        return None

    minimum = maximum = arr[0]

    for num in arr:
        if num < minimum:
            minimum = num
        if num > maximum:
            maximum = num

    print("Min =", minimum)
    print("Max =", maximum)


