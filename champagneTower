def champagneTower(poured, query_row, query_glass):
    dp = [[0] * (r + 1) for r in range(101)]
    dp[0][0] = poured

    for r in range(query_row + 1):
        for c in range(r + 1):
            excess = (dp[r][c] - 1) / 2
            if excess > 0:
                dp[r + 1][c] += excess
                dp[r + 1][c + 1] += excess

    return min(1, dp[query_row][query_glass])

# Examples
print(champagneTower(1,1,1))
print(champagneTower(2,1,1))
