from itertools import combinations

def knapsack(weights, values, capacity):

    n = len(weights)

    bestValue = 0
    bestItems = []

    for r in range(n+1):

        for comb in combinations(range(n), r):

            weight = 0
            value = 0

            for i in comb:
                weight += weights[i]
                value += values[i]

            if weight <= capacity and value > bestValue:
                bestValue = value
                bestItems = list(comb)

    return bestItems, bestValue


weights = [2,3,1]
values = [4,5,3]
capacity = 4

items, value = knapsack(weights, values, capacity)

print("Selected Items =", items)
print("Total Value =", value)
