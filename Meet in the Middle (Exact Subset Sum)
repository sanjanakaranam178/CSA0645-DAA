from itertools import combinations

def exactSubset(arr, target):

    n = len(arr)

    for r in range(n + 1):
        for comb in combinations(arr, r):
            if sum(comb) == target:
                return True

    return False


# Test Cases
print(exactSubset([1,3,9,2,7,12],15))

print(exactSubset([3,34,4,12,5,2],15))
