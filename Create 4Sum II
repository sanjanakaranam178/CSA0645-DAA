def fourSumCount(A, B, C, D):

    dic = {}

    for a in A:
        for b in B:
            dic[a+b] = dic.get(a+b,0)+1

    count = 0

    for c in C:
        for d in D:
            count += dic.get(-(c+d),0)

    return count


# Test Cases
A=[1,2]
B=[-2,-1]
C=[-1,2]
D=[0,2]

print(fourSumCount(A,B,C,D))

print(fourSumCount([0],[0],[0],[0]))
